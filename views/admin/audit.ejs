<%- include('../partials/header') %>

<!-- Admin Navbar -->
<nav class="navbar navbar-expand-lg navbar-custom">
  <div class="container">
    <a class="navbar-brand" href="/vote_admin/dashboard">
      <img src="<%= schoolLogo %>" alt="<%= schoolName %>" class="navbar-logo" onerror="this.style.display='none';">
      <span class="brand-text">Admin Panel</span>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav" style="border-color: var(--border-glass);">
      <i class="bi bi-list" style="color: var(--text-primary); font-size: 1.5rem;"></i>
    </button>
    <div class="collapse navbar-collapse" id="adminNav">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item">
          <a class="nav-link" href="/vote_admin/logout">
            <i class="bi bi-box-arrow-right me-1"></i>Logout
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<div class="main-content">
  <div class="container">
    <!-- Admin Navigation Pills -->
    <div class="admin-nav-pills">
      <a href="/vote_admin/dashboard"><i class="bi bi-speedometer2 me-1"></i>Analytics</a>
      <a href="/vote_admin/posts"><i class="bi bi-collection me-1"></i>Manage Posts</a>
      <a href="/vote_admin/audit" class="active"><i class="bi bi-journal-text me-1"></i>Audit Trail</a>
      <a href="/vote_admin/users"><i class="bi bi-people me-1"></i>Manage Users</a>
    </div>

    <!-- Page Header -->
    <div class="actions-bar">
      <div class="page-header" style="margin-bottom: 0;">
        <h1><i class="bi bi-journal-text me-2" style="color: var(--accent-primary-light);"></i>Audit Trail</h1>
        <p>Complete record of every vote cast by <%= schoolName %> voters.</p>
      </div>
      <div>
        <form action="/vote_admin/audit" method="GET" style="display: flex; gap: 0.75rem; align-items: center;">
          <select name="postId" class="filter-select" onchange="this.form.submit()">
            <option value="">All Positions</option>
            <% posts.forEach(p => { %>
              <option value="<%= p._id %>" <%= selectedPostId === p._id.toString() ? 'selected' : '' %>><%= p.title %></option>
            <% }) %>
          </select>
          <a href="/vote_admin/audit/export<%= selectedPostId ? '?postId=' + selectedPostId : '' %>" class="btn-primary-custom" style="padding: 0.5rem 1rem; border-radius: 8px; white-space: nowrap;">
            <i class="bi bi-filetype-csv me-1"></i> Export
          </a>
        </form>
      </div>
    </div>

    <div class="glass-card" style="padding: 0; overflow: hidden;">
      <% if (votes.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon"><i class="bi bi-journal-text"></i></div>
          <h3>No Votes Recorded</h3>
          <p>Votes will appear here as voters participate in the elections.</p>
        </div>
      <% } else { %>
        <table class="table-custom">
          <thead>
            <tr>
              <th>#</th>
              <th>Voter Email</th>
              <th>Voter Name</th>
              <th>Position</th>
              <th>Voted For</th>
              <th>Timestamp</th>
            </tr>
          </thead>
          <tbody>
            <% votes.forEach((vote, i) => { %>
              <tr>
                <td style="color: var(--text-muted);"><%= i + 1 %></td>
                <td>
                  <span style="color: var(--accent-primary-light); font-weight: 500;">
                    <i class="bi bi-envelope me-1" style="font-size:0.8rem;"></i>
                    <%= vote.voter ? vote.voter.email : 'Deleted User' %>
                  </span>
                </td>
                <td><%= vote.voter ? vote.voter.displayName : '—' %></td>
                <td>
                  <span class="candidate-chip">
                    <i class="bi bi-award me-1" style="font-size:0.7rem; color: var(--accent-warning);"></i>
                    <%= vote.post ? vote.post.title : 'Deleted Post' %>
                  </span>
                </td>
                <td><strong><%= vote.candidateName %></strong></td>
                <td style="font-size: 0.85rem; color: var(--text-secondary);">
                  <%= new Date(vote.createdAt).toLocaleString('en-IN', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <% if (votes.length > 0) { %>
      <div style="margin-top: 1rem; text-align: right; color: var(--text-muted); font-size: 0.85rem;">
        <i class="bi bi-list-check me-1"></i>Showing <%= votes.length %> record<%= votes.length !== 1 ? 's' : '' %>
      </div>
    <% } %>
  </div>
</div>

<!-- Footer -->
<footer class="vg-site-footer">
  <div class="container">
    <div class="vg-footer-inner">
      <img src="<%= schoolLogo %>" alt="<%= schoolName %>" class="footer-logo" onerror="this.style.display='none';">
      <span><%= schoolName %> <%= schoolTagline %> — Election Management System</span>
    </div>
  </div>
</footer>

<%- include('../partials/footer') %>
