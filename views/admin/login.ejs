<%- include('../partials/header') %>

<div class="login-wrapper">
  <div class="login-card">
    <div class="vg-logo-container">
      <img src="<%= schoolLogo %>" alt="<%= schoolName %>" class="vg-logo" onerror="this.style.display='none';">
    </div>
    <div class="logo-icon" style="background: linear-gradient(135deg, #f59e0b, #ef4444);">
      <i class="bi bi-shield-lock" style="color: #fff;"></i>
    </div>
    <h1>Admin Panel</h1>
    <p>Authorized personnel only. Enter your credentials to manage the <%= schoolName %> elections.</p>
    <form action="/vote_admin/login" method="POST" style="text-align: left;">
      <div class="form-group">
        <label for="username"><i class="bi bi-person me-1"></i>Username</label>
        <input type="text" id="username" name="username" class="form-control-custom" placeholder="Enter admin username" required autocomplete="username">
      </div>
      <div class="form-group">
        <label for="password"><i class="bi bi-key me-1"></i>Password</label>
        <input type="password" id="password" name="password" class="form-control-custom" placeholder="Enter password" required autocomplete="current-password">
      </div>
      <div style="text-align: center; margin-top: 1.5rem;">
        <button type="submit" class="btn-primary-custom" id="btn-admin-login" style="width: 100%; justify-content: center;">
          <i class="bi bi-box-arrow-in-right"></i> Sign In
        </button>
      </div>
    </form>
    <div style="margin-top: 1.5rem;">
      <a href="/login" style="font-size: 0.85rem; color: var(--text-muted);">
        <i class="bi bi-arrow-left me-1"></i>Back to Voter Login
      </a>
    </div>
    <div class="vg-footer-branding">
      <span><%= schoolName %> <%= schoolTagline %> — EMS</span>
      <div style="margin-top: 5px; font-size: 0.7rem; opacity: 0.8;">
        Developed By <a href="https://github.com/divyanshyadav2828/" target="_blank" style="color: var(--accent-primary-light); text-decoration: none; font-weight: 600;">Divyansh</a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
