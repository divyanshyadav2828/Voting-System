<%- include('../partials/header') %>

<!-- Admin Navbar -->
<nav class="navbar navbar-expand-lg navbar-custom">
  <div class="container">
    <a class="navbar-brand" href="/vote_admin/dashboard">
      <img src="<%= schoolLogo %>" alt="<%= schoolName %>" class="navbar-logo" onerror="this.style.display='none';">
      <span class="brand-text">Admin Panel</span>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav" style="border-color: var(--border-glass);">
      <i class="bi bi-list" style="color: var(--text-primary); font-size: 1.5rem;"></i>
    </button>
    <div class="collapse navbar-collapse" id="adminNav">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item">
          <a class="nav-link" href="/vote_admin/logout" id="btn-admin-logout">
            <i class="bi bi-box-arrow-right me-1"></i>Logout
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<div class="main-content">
  <div class="container">
    <!-- Admin Navigation Pills -->
    <div class="admin-nav-pills mb-4">
      <a href="/vote_admin/dashboard"><i class="bi bi-speedometer2 me-1"></i>Analytics</a>
      <a href="/vote_admin/posts"><i class="bi bi-collection me-1"></i>Manage Posts</a>
      <a href="/vote_admin/audit"><i class="bi bi-journal-text me-1"></i>Audit Trail</a>
      <a href="/vote_admin/users" class="active"><i class="bi bi-people me-1"></i>Manage Users</a>
    </div>

    <!-- Page Header -->
    <div class="page-header">
      <h1><i class="bi bi-people me-2" style="color: var(--accent-primary-light);"></i>Manage Users</h1>
      <p>Edit the allowed voters lists. Place one user ID per line.</p>
    </div>

    <div class="glass-card">
      <form action="/vote_admin/users" method="POST">
        <div class="row">
          <div class="col-md-6 mb-3">
            <label for="teachersCsv" class="form-label" style="color: var(--text-primary); font-weight: 500;">
              Teachers UID List (Weight: <%= process.env.teachers || 2 %>)
            </label>
            <textarea id="teachersCsv" name="teachersCsv" class="form-control" rows="15" style="background: rgba(255,255,255,0.05); color: #fff; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;"><%= teachersText %></textarea>
            <small style="color: var(--text-secondary); margin-top: 5px; display: block;">One UID per line (e.g., teacher1).</small>
          </div>
          <div class="col-md-6 mb-3">
            <label for="studentsCsv" class="form-label" style="color: var(--text-primary); font-weight: 500;">
              Students UID List (Weight: <%= process.env.students || 1 %>)
            </label>
            <textarea id="studentsCsv" name="studentsCsv" class="form-control" rows="15" style="background: rgba(255,255,255,0.05); color: #fff; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;"><%= studentsText %></textarea>
            <small style="color: var(--text-secondary); margin-top: 5px; display: block;">One UID per line.</small>
          </div>
        </div>
        
        <div class="mt-3">
          <button type="submit" class="btn-primary-custom w-100">
            <i class="bi bi-save me-2"></i> Save User Lists
          </button>
        </div>
      </form>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>
