<%- include('../partials/header') %>

<!-- Admin Navbar -->
<nav class="navbar navbar-expand-lg navbar-custom">
  <div class="container">
    <a class="navbar-brand" href="/vote_admin/dashboard">
      <img src="<%= schoolLogo %>" alt="<%= schoolName %>" class="navbar-logo" onerror="this.style.display='none';">
      <span class="brand-text">Admin Panel</span>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav" style="border-color: var(--border-glass);">
      <i class="bi bi-list" style="color: var(--text-primary); font-size: 1.5rem;"></i>
    </button>
    <div class="collapse navbar-collapse" id="adminNav">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item">
          <a class="nav-link" href="/vote_admin/logout">
            <i class="bi bi-box-arrow-right me-1"></i>Logout
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<div class="main-content">
  <div class="container">
    <!-- Admin Navigation Pills -->
    <div class="admin-nav-pills">
      <a href="/vote_admin/dashboard"><i class="bi bi-speedometer2 me-1"></i>Analytics</a>
      <a href="/vote_admin/posts" class="active"><i class="bi bi-collection me-1"></i>Manage Posts</a>
      <a href="/vote_admin/audit"><i class="bi bi-journal-text me-1"></i>Audit Trail</a>
      <a href="/vote_admin/users"><i class="bi bi-people me-1"></i>Manage Users</a>
    </div>

    <!-- Page Header -->
    <div class="actions-bar">
      <div class="page-header" style="margin-bottom: 0;">
        <h1><i class="bi bi-collection me-2" style="color: var(--accent-primary-light);"></i>Election Posts</h1>
        <p>Create and manage voting positions for <%= schoolName %> elections.</p>
      </div>
      <a href="/vote_admin/posts/new" class="btn-primary-custom">
        <i class="bi bi-plus-lg"></i> New Post
      </a>
    </div>

    <% if (posts.length === 0) { %>
      <div class="glass-card">
        <div class="empty-state">
          <div class="empty-icon"><i class="bi bi-collection"></i></div>
          <h3>No Election Posts Yet</h3>
          <p>Create your first voting post to start the elections — e.g. Head Boy, Head Girl, Sports Captain.</p>
          <a href="/vote_admin/posts/new" class="btn-primary-custom" style="margin-top: 1rem;">
            <i class="bi bi-plus-lg"></i> Create First Post
          </a>
        </div>
      </div>
    <% } else { %>
      <div class="glass-card" style="padding: 0; overflow: hidden;">
        <table class="table-custom">
          <thead>
            <tr>
              <th>Position</th>
              <th>Candidates</th>
              <th>Status</th>
              <th>Created</th>
              <th style="text-align: right;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% posts.forEach(post => { %>
              <tr>
                <td>
                  <strong><i class="bi bi-award me-1" style="color: var(--accent-warning);"></i><%= post.title %></strong>
                  <% if (post.description) { %>
                    <br><span style="font-size: 0.8rem; color: var(--text-muted);"><%= post.description.substring(0, 60) %><%= post.description.length > 60 ? '...' : '' %></span>
                  <% } %>
                </td>
                <td>
                  <% post.candidates.forEach(c => { %>
                    <span class="candidate-chip">
                      <%= c.name %>
                    </span>
                  <% }) %>
                </td>
                <td>
                  <% if (post.isActive) { %>
                    <span class="badge badge-active mb-1 d-block" style="width: fit-content;"><i class="bi bi-circle-fill me-1" style="font-size:0.4rem;"></i>Voting Active</span>
                  <% } else { %>
                    <span class="badge badge-inactive mb-1 d-block" style="width: fit-content;">Voting Closed</span>
                  <% } %>
                  
                  <% if (post.isResultsPublished) { %>
                    <span class="badge" style="background: rgba(34, 197, 94, 0.1); color: var(--accent-success); width: fit-content;"><i class="bi bi-broadcast me-1"></i>Results LIVE</span>
                  <% } else { %>
                    <span class="badge" style="background: var(--bg-hover); color: var(--text-muted); width: fit-content;"><i class="bi bi-eye-slash me-1"></i>Results Hidden</span>
                  <% } %>
                </td>
                <td style="font-size: 0.85rem; color: var(--text-secondary);">
                  <%= new Date(post.createdAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                </td>
                <td style="text-align: right;">
                  <div style="display: flex; gap: 0.5rem; justify-content: flex-end; align-items: center;">
                    <form id="toggle-res-<%= post._id %>" action="/vote_admin/posts/<%= post._id %>/toggle-results" method="POST" style="margin:0;">
                      <button type="submit" class="btn-sm-custom" style="padding:0.4rem 0.6rem; border:none; background-color: <%= post.isResultsPublished ? 'var(--bg-hover)' : 'rgba(34,197,94,0.1)' %>; color: <%= post.isResultsPublished ? 'var(--text-muted)' : 'var(--accent-success)' %>;">
                        <i class="bi <%= post.isResultsPublished ? 'bi-eye-slash' : 'bi-broadcast' %>"></i> <%= post.isResultsPublished ? 'Hide' : 'Publish' %>
                      </button>
                    </form>
                    <a href="/vote_admin/posts/<%= post._id %>/edit" class="btn-secondary-custom btn-sm-custom">
                      <i class="bi bi-pencil"></i>
                    </a>
                    <form id="delete-<%= post._id %>" action="/vote_admin/posts/<%= post._id %>?_method=DELETE" method="POST" style="margin:0;">
                      <button type="button" class="btn-danger-custom" onclick="confirmDelete('delete-<%= post._id %>')">
                        <i class="bi bi-trash3"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<!-- Footer -->
<footer class="vg-site-footer">
  <div class="container">
    <div class="vg-footer-inner">
      <img src="<%= schoolLogo %>" alt="<%= schoolName %>" class="footer-logo" onerror="this.style.display='none';">
      <span><%= schoolName %> <%= schoolTagline %> — Election Management System</span>
    </div>
  </div>
</footer>

<%- include('../partials/footer') %>
