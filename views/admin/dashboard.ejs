<%- include('../partials/header') %>

<!-- Admin Navbar -->
<nav class="navbar navbar-expand-lg navbar-custom">
  <div class="container">
    <a class="navbar-brand" href="/vote_admin/dashboard">
      <img src="<%= schoolLogo %>" alt="<%= schoolName %>" class="navbar-logo" onerror="this.style.display='none';">
      <span class="brand-text">Admin Panel</span>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav" style="border-color: var(--border-glass);">
      <i class="bi bi-list" style="color: var(--text-primary); font-size: 1.5rem;"></i>
    </button>
    <div class="collapse navbar-collapse" id="adminNav">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item">
          <a class="nav-link" href="/vote_admin/logout" id="btn-admin-logout">
            <i class="bi bi-box-arrow-right me-1"></i>Logout
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<div class="main-content">
  <div class="container">
    <!-- Admin Navigation Pills -->
    <div class="admin-nav-pills">
      <a href="/vote_admin/dashboard" class="active"><i class="bi bi-speedometer2 me-1"></i>Analytics</a>
      <a href="/vote_admin/posts"><i class="bi bi-collection me-1"></i>Manage Posts</a>
      <a href="/vote_admin/audit"><i class="bi bi-journal-text me-1"></i>Audit Trail</a>
      <a href="/vote_admin/users"><i class="bi bi-people me-1"></i>Manage Users</a>
    </div>

    <!-- Page Header -->
    <div class="page-header">
      <h1><i class="bi bi-bar-chart-line me-2" style="color: var(--accent-primary-light);"></i>Election Analytics</h1>
      <p>Complete overview of all <%= schoolName %> election results and voter participation.</p>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon purple"><i class="bi bi-collection"></i></div>
        <div class="stat-value"><%= totalPosts %></div>
        <div class="stat-label">Election Posts</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon green"><i class="bi bi-people"></i></div>
        <div class="stat-value"><%= totalUsers %></div>
        <div class="stat-label">Registered Voters</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon orange"><i class="bi bi-check2-all"></i></div>
        <div class="stat-value" style="display: flex; flex-direction: column; align-items: center; line-height: 1.2;">
          <div><%= analytics.reduce((sum, a) => sum + a.totalVotes, 0) %> <span style="font-size: 0.9rem; color: var(--text-secondary); font-weight: normal;">(Raw)</span></div>
          <div style="font-size: 1.2rem; color: var(--accent-warning); margin-top: 4px;"><%= analytics.reduce((sum, a) => sum + a.totalWeightedVotes, 0) %> <span style="font-size: 0.75rem; color: var(--text-secondary); font-weight: normal;">(Weighted)</span></div>
        </div>
        <div class="stat-label">Total Votes Cast</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon pink"><i class="bi bi-percent"></i></div>
        <div class="stat-value"><%= totalUsers > 0 ? ((analytics.reduce((sum, a) => sum + a.totalVotes, 0) / (totalUsers * (totalPosts || 1)) ) * 100).toFixed(0) : 0 %>%</div>
        <div class="stat-label">Avg. Participation</div>
      </div>
    </div>

    <!-- Analytics per Post -->
    <% if (analytics.length === 0) { %>
      <div class="glass-card">
        <div class="empty-state">
          <div class="empty-icon"><i class="bi bi-bar-chart"></i></div>
          <h3>No Election Data Yet</h3>
          <p>Create voting posts and wait for voters to cast their votes.</p>
          <a href="/vote_admin/posts/new" class="btn-primary-custom" style="margin-top: 1rem;">
            <i class="bi bi-plus-lg"></i> Create Election Post
          </a>
        </div>
      </div>
    <% } else { %>
      <% analytics.forEach((item, idx) => { %>
        <div class="analytics-card">
          <div class="analytics-card-header">
            <h3><i class="bi bi-award me-2" style="color: var(--accent-warning);"></i><%= item.post.title %></h3>
            <div style="display: flex; align-items: center; gap: 1rem;">
              <span style="font-size: 0.85rem; color: var(--text-secondary);">
                <i class="bi bi-people me-1"></i><%= item.totalVotes %> / <%= totalUsers %> voted (Raw)
              </span>
              <span style="font-size: 0.85rem; color: var(--accent-warning);">
                <i class="bi bi-star me-1" style="color: gold;"></i><%= item.totalWeightedVotes %> Weighted
              </span>
              <% if (item.post.isActive) { %>
                <span class="badge badge-active">Active</span>
              <% } else { %>
                <span class="badge badge-inactive">Closed</span>
              <% } %>
            </div>
          </div>
          <div class="analytics-card-body">
            <div class="analytics-row">
              <!-- Candidate Results -->
              <div>
                <h4 class="section-title" style="font-size: 1rem; margin-bottom: 1.25rem;">
                  <i class="bi bi-trophy me-1" style="color: var(--accent-warning);"></i>Results
                </h4>
                <% if (item.candidateStats.length === 0) { %>
                  <p style="color: var(--text-secondary); font-size: 0.9rem;">No candidates added.</p>
                <% } else { %>
                  <% item.candidateStats.forEach((c, rank) => { %>
                    <div class="result-row">
                      <div class="result-rank <%= rank === 0 && item.totalVotes > 0 ? 'gold' : '' %>">
                        <% if (rank === 0 && item.totalVotes > 0) { %>
                          <i class="bi bi-trophy-fill" style="font-size:0.7rem;"></i>
                        <% } else { %>
                          <%= rank + 1 %>
                        <% } %>
                      </div>
                      <div class="result-info">
                        <div class="result-name"><%= c.name %></div>
                        <div class="result-stats">
                          <span><%= c.votes %> vote<%= c.votes !== 1 ? 's' : '' %> <small class="text-muted">(Raw)</small></span>
                          <span style="color: var(--accent-warning); font-weight: 500;"><%= c.weightedVotes %> Weighted</span>
                          <span><%= c.percentage %>%</span>
                        </div>
                        <div class="progress-bar-wrapper" style="margin-top: 6px;">
                          <div class="progress-bar-fill <%= rank === 0 ? '' : 'green' %>" style="width: <%= c.percentage %>%;"></div>
                        </div>
                      </div>
                    </div>
                  <% }) %>
                <% } %>
              </div>

              <!-- Chart -->
              <div>
                <h4 class="section-title" style="font-size: 1rem; margin-bottom: 1.25rem;">
                  <i class="bi bi-pie-chart me-1" style="color: var(--accent-secondary);"></i>Vote Distribution
                </h4>
                <% if (item.totalVotes > 0) { %>
                  <div class="chart-container">
                    <canvas id="chart-<%= idx %>"></canvas>
                  </div>
                <% } else { %>
                  <div class="empty-state" style="padding: 2rem 1rem;">
                    <div class="empty-icon" style="font-size: 2rem;"><i class="bi bi-pie-chart"></i></div>
                    <p style="font-size: 0.85rem;">Awaiting votes from voters</p>
                  </div>
                <% } %>

                <% if (item.leader && item.totalVotes > 0) { %>
                  <div style="margin-top: 1rem; text-align: center;">
                    <div class="leader-badge">
                      <i class="bi bi-trophy-fill"></i>
                      Leading: <%= item.leader.name %> (<%= item.leader.votes %> votes, <%= item.leader.percentage %>%)
                    </div>
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<!-- Footer -->
<footer class="vg-site-footer">
  <div class="container">
    <div class="vg-footer-inner">
      <img src="<%= schoolLogo %>" alt="<%= schoolName %>" class="footer-logo" onerror="this.style.display='none';">
      <span><%= schoolName %> <%= schoolTagline %> — Election Management System</span>
    </div>
  </div>
</footer>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
  const colors = [
    '#6366f1', '#06b6d4', '#10b981', '#f59e0b', '#ef4444',
    '#ec4899', '#8b5cf6', '#14b8a6', '#f97316', '#64748b',
    '#a855f7', '#22d3ee', '#84cc16', '#eab308', '#f43f5e'
  ];

  <% analytics.forEach((item, idx) => { %>
    <% if (item.totalVotes > 0) { %>
      new Chart(document.getElementById('chart-<%= idx %>'), {
        type: 'doughnut',
        data: {
          labels: [<%= item.candidateStats.map(c => JSON.stringify(c.name)).join(',') %>],
          datasets: [{
            data: [<%= item.candidateStats.map(c => c.votes).join(',') %>],
            backgroundColor: colors.slice(0, <%= item.candidateStats.length %>),
            borderWidth: 0,
            hoverOffset: 8,
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          cutout: '60%',
          plugins: {
            legend: {
              position: 'bottom',
              labels: {
                color: '#94a3b8',
                font: { family: 'Inter', size: 12 },
                padding: 16,
                usePointStyle: true,
                pointStyleWidth: 12,
              }
            }
          }
        }
      });
    <% } %>
  <% }) %>
</script>

<%- include('../partials/footer') %>
