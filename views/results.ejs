<%- include('partials/header') %>

<div class="main-content">
  <div class="container">
    <div class="page-header text-center" style="margin-bottom: 3rem;">
      <h1 style="color: var(--text-primary); font-size: 2.5rem; font-weight: 700; letter-spacing: -1px;">
        <i class="bi bi-broadcast me-2" style="color: var(--accent-secondary);"></i>Live Election Results
      </h1>
      <p style="color: var(--text-secondary); max-width: 600px; margin: 0 auto; font-size: 1.1rem;">
        Official results for concluded student council elections. Results are published here exclusively upon administrative approval.
      </p>
    </div>

    <!-- Analytics per Post -->
    <% if (analytics.length === 0) { %>
      <div class="row justify-content-center">
        <div class="col-md-8">
          <div class="glass-card" style="padding: 4rem 2rem;">
            <div class="empty-state">
              <div class="empty-icon" style="font-size: 4rem; color: var(--text-muted); opacity:0.5;"><i class="bi bi-lock"></i></div>
              <h3 style="margin-top: 1rem;">No Results Available</h3>
              <p>The election board has not published any results at this time. Please check back later when voting has concluded and tallies are approved.</p>
              <a href="/" class="btn-primary-custom" style="margin-top: 1rem;">
                <i class="bi bi-house me-1"></i> Return Home
              </a>
            </div>
          </div>
        </div>
      </div>
    <% } else { %>
      <% analytics.forEach((item, idx) => { %>
        <div class="glass-card mb-5" style="border-top: 4px solid var(--accent-primary);">
          <div class="analytics-card-header d-flex justify-content-between align-items-center mb-4">
            <div>
              <h2 style="margin: 0; display:flex; align-items: center;"><i class="bi bi-award me-2" style="color: var(--accent-warning);"></i><%= item.post.title %></h2>
              <% if (item.post.description) { %>
                <p class="text-muted mt-2 mb-0"><%= item.post.description %></p>
              <% } %>
            </div>
            <div class="text-end">
              <span class="badge" style="background: rgba(34, 197, 94, 0.1); color: var(--accent-success); font-size: 1rem; padding: 0.5rem 1rem;">
                <i class="bi bi-check-circle-fill me-1"></i>Official Results
              </span>
              <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 5px;">
                Total Votes: <strong><%= item.totalVotes %></strong>
              </div>
            </div>
          </div>
          
          <div class="row gx-5">
            <!-- Candidate Results -->
            <div class="col-md-7 mb-4 mb-md-0">
              <h4 class="section-title" style="font-size: 1.1rem; margin-bottom: 1.5rem;">
                <i class="bi bi-bar-chart-steps me-1" style="color: var(--accent-primary-light);"></i>Standings
              </h4>
              <% if (item.candidateStats.length === 0) { %>
                <p style="color: var(--text-secondary); font-size: 0.9rem;">No candidates.</p>
              <% } else { %>
                <div class="results-list">
                  <% item.candidateStats.forEach((c, rank) => { %>
                    <div style="background: var(--bg-hover); border-radius: 12px; padding: 1rem 1.25rem; margin-bottom: 1rem; border: 1px solid var(--border-glass);">
                      <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="d-flex align-items-center">
                          <div style="width: 30px; height: 30px; border-radius: 50%; background: <%= rank === 0 && item.totalVotes > 0 ? 'var(--accent-warning)' : 'var(--bg-input)' %>; color: <%= rank === 0 && item.totalVotes > 0 ? '#000' : 'var(--text-primary)' %>; display: flex; align-items: center; justify-content: center; font-weight: bold; margin-right: 1rem; font-size: 0.9rem;">
                            <% if (rank === 0 && item.totalVotes > 0) { %>
                              <i class="bi bi-trophy-fill" style="font-size:0.7rem;"></i>
                            <% } else { %>
                              <%= rank + 1 %>
                            <% } %>
                          </div>
                          <strong style="font-size: 1.1rem;"><%= c.name %></strong>
                        </div>
                        <div style="text-align: right; font-weight: 600;">
                          <%= c.percentage %>% <span style="color: var(--text-muted); font-size: 0.85rem; font-weight: 400; margin-left: 5px;">(<%= c.votes %> votes)</span>
                        </div>
                      </div>
                      <div class="progress" style="height: 10px; background-color: var(--bg-input); border-radius: 6px;">
                        <div class="progress-bar <%= rank === 0 && item.totalVotes > 0 ? 'bg-success' : 'bg-primary' %>" role="progressbar" style="width: <%= c.percentage %>%; border-radius: 6px;" aria-valuenow="<%= c.percentage %>" aria-valuemin="0" aria-valuemax="100"></div>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>

            <!-- Chart -->
            <div class="col-md-5 d-flex flex-column justify-content-center align-items-center" style="background: var(--bg-card); border-radius: 12px; padding: 2rem; border: 1px solid var(--border-glass);">
              <% if (item.totalVotes > 0) { %>
                <div style="position: relative; width: 100%; max-width: 250px; aspect-ratio: 1/1;">
                  <canvas id="chart-<%= idx %>"></canvas>
                </div>
                <% if (item.leader && item.totalVotes > 0) { %>
                  <div style="margin-top: 1.5rem; text-align: center;">
                    <div style="background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.3); color: var(--accent-warning); padding: 0.5rem 1rem; border-radius: 20px; font-weight: 600; font-size: 0.95rem; display: inline-block;">
                      <i class="bi bi-star-fill me-1"></i>Winner: <%= item.leader.name %>
                    </div>
                  </div>
                <% } %>
              <% } else { %>
                <div class="empty-state">
                  <div class="empty-icon" style="font-size: 3rem;"><i class="bi bi-pie-chart"></i></div>
                  <p style="font-size: 0.95rem;">No votes cast yet.</p>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>

<% if (analytics.length > 0) { %>
<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
  const colors = [
    '#6366f1', '#10b981', '#f59e0b', '#06b6d4', '#ef4444',
    '#ec4899', '#8b5cf6', '#14b8a6', '#f97316', '#64748b'
  ];

  <% analytics.forEach((item, idx) => { %>
    <% if (item.totalVotes > 0) { %>
      new Chart(document.getElementById('chart-<%= idx %>'), {
        type: 'doughnut',
        data: {
          labels: [<%= item.candidateStats.map(c => JSON.stringify(c.name)).join(',') %>],
          datasets: [{
            data: [<%= item.candidateStats.map(c => c.votes).join(',') %>],
            backgroundColor: colors.slice(0, <%= item.candidateStats.length %>),
            borderWidth: 0,
            hoverOffset: 4,
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          cutout: '70%',
          plugins: {
            legend: {
              display: false // Using custom legend in UI
            },
            tooltip: {
              callbacks: {
                label: function(context) {
                  return ' ' + context.label + ': ' + context.raw + ' votes';
                }
              }
            }
          }
        }
      });
    <% } %>
  <% }) %>
</script>
<% } %>
