<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= schoolName %> Voting Portal — Cast your vote securely.">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %><%= schoolName %> Vote</title>

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <!-- Custom CSS -->
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>

<!-- Background Orbs -->
<div class="bg-orbs">
  <div class="orb"></div>
  <div class="orb"></div>
  <div class="orb"></div>
</div>

<!-- Flash Messages -->
<div class="flash-container">
  <% if (typeof success_msg !== 'undefined' && success_msg.length > 0) { %>
    <% success_msg.forEach(msg => { %>
      <div class="flash-msg success"><i class="bi bi-check-circle-fill me-2"></i><%= msg %></div>
    <% }) %>
  <% } %>
  <% if (typeof error_msg !== 'undefined' && error_msg.length > 0) { %>
    <% error_msg.forEach(msg => { %>
      <div class="flash-msg error"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= msg %></div>
    <% }) %>
  <% } %>
  <% if (typeof error !== 'undefined' && error.length > 0) { %>
    <% error.forEach(msg => { %>
      <div class="flash-msg error"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= msg %></div>
    <% }) %>
  <% } %>
</div>
