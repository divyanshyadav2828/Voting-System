<%- include('partials/header') %>

<div class="unauthorized-wrapper">
  <div class="unauthorized-card" style="border-color: var(--border-glass);">
    <div class="error-icon" style="background: rgba(99, 102, 241, 0.15);">
      <i class="bi bi-exclamation-triangle" style="color: var(--accent-primary-light);"></i>
    </div>
    <h1 style="margin-bottom: 0.75rem;"><%= title %></h1>
    <p style="color: var(--text-secondary); margin-bottom: 2rem;">
      <%= typeof message !== 'undefined' ? message : 'An unexpected error occurred.' %>
    </p>
    <a href="/" class="btn-secondary-custom">
      <i class="bi bi-house"></i>
      Go Home
    </a>
  </div>
</div>

<%- include('partials/footer') %>
